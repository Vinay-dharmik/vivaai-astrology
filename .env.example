# VivaAI Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ─── Razorpay (Payments) ───────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ─── NextAuth (Admin Panel Auth) ──────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://vivaai.in

# ─── Google OAuth (Admin Login) ───────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://vivaai.in/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ─── Google Analytics & AdSense ───────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# ─── Database (Optional — for future CMS features) ───
# Get from: https://neon.tech or https://supabase.com
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
